# AUDIO_PROCESSOR:
# - local: run Demucs on this machine. Recommended for local testing.
# - modal: forward uploads to the Modal backend. Recommended for production.
AUDIO_PROCESSOR="local"

# DEMUCS_COMMAND: Optional path to a local Demucs executable.
# Defaults to ./.venv/bin/demucs when present, otherwise demucs on PATH.
DEMUCS_COMMAND="./.venv/bin/demucs"

# DEMUCS_DEVICE: Use cpu for the most reliable macOS local test.
# Apple Silicon can try mps, but CPU is usually safer for compatibility.
DEMUCS_DEVICE="cpu"

# MODAL_WEBHOOK_URL: Required for invoking your custom Modal backend.
# Run `modal deploy modal_app.py` on your machine to get the webhook URL.
MODAL_WEBHOOK_URL="https://YOUR_WORKSPACE_NAME--uvr5-demucs-app-fastapi-app.modal.run/separate"

# MODAL_AUTH_TOKEN: Optional token if you protected the webhook.
# Use the same value in .env.local, Vercel env vars, and the Modal Secret.
MODAL_AUTH_TOKEN="YOUR_SECRET_TOKEN"

# BLOB_READ_WRITE_TOKEN: Required for Vercel Blob production storage.
# Public Blob store token. Source files are deleted after processing;
# result files are deleted after RESULT_TTL_SECONDS.
# Add the same value to the Modal Secret named ai-vocal-remover-secrets.
# Do not need this for local Demucs testing.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Supabase Auth / Postgres. Browser code uses VITE_* values; serverless API
# routes use the service role key for profile/job updates.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Stripe Checkout / portal.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
APP_BASE_URL="http://localhost:3000"

# Optional observability.
SENTRY_DSN=""
VITE_SENTRY_DSN=""
